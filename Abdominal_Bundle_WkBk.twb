      <column caption='Cmp Abdominal Bundle Ordered' datatype='integer' name='[Calculation_61643028114812928]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Abdominal Bundle Order Date])&#13;&#10;THEN 0&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>

      <column caption='% Comp Abdominal Bundle Ordered' datatype='real' name='[Calculation_61643028167589898]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_61643028114812928]) / COUNT([SURGERY_DATE])) * 100' />
